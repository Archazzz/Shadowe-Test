/* app.wxss - 全局样式 */
@import './styles/main.wxss';

page {
  background-color: #F7F5FF;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'SF Pro SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  color: #1A1A2E;
  font-size: 14px;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, button, input, textarea {
  box-sizing: border-box;
}

button {
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  background: transparent;
  border-radius: 0;
}

button::after {
  border: none;
}

input {
  border: none;
  outline: none;
}

textarea {
  border: none;
  outline: none;
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background-color: #F7F5FF;
  padding-bottom: calc(constant(safe-area-inset-bottom) + 16px);
  padding-bottom: calc(env(safe-area-inset-bottom) + 16px);
}

/* 滚动容器 */
.scroll-container {
  height: 100%;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 内容区域 */
.content-area {
  padding: 0 16px;
}

/* 顶部导航栏占位 */
.nav-bar-placeholder {
  height: 44px;
  background: transparent;
}

/* 底部导航栏占位 */
.tab-bar-placeholder {
  height: 50px;
}
