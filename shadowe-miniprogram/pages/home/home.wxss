/* pages/home/home.wxss */

.home-header {
  padding: 16px;
}

/* 品牌栏 */
.brand-bar {
  margin-bottom: 24px;
}

.brand-logo {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 16px;
  margin-right: 8px;
}

.brand-name {
  margin-right: 8px;
}

.pro-badge {
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  color: #FFFFFF;
  padding: 2px 8px;
}

.header-actions {
  gap: 12px;
}

.notification-icon {
  position: relative;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #333344;
}

.badge-dot {
  position: absolute;
  top: 2px;
  right: 2px;
  width: 8px;
  height: 8px;
  background: #FF3B30;
  border-radius: 50%;
  border: 2px solid #F7F5FF;
}

.user-avatar {
  width: 32px;
  height: 32px;
}

/* 主标题区 */
.main-title-section {
  text-align: center;
  margin-bottom: 24px;
}

.main-title {
  display: block;
  margin-bottom: 4px;
}

.sub-title {
  display: block;
  margin-bottom: 12px;
}

.description {
  display: block;
  max-width: 280px;
  margin: 0 auto 24px;
  color: #666677;
}

/* AI 视觉插画 */
.ai-illustration {
  position: relative;
  width: 280px;
  height: 280px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-avatar-ring {
  position: absolute;
  border-radius: 50%;
  border: 2px solid rgba(139, 108, 246, 0.15);
}

.ring-1 {
  width: 200px;
  height: 200px;
  animation: breathe 3s ease-in-out infinite;
}

.ring-2 {
  width: 160px;
  height: 160px;
  border-color: rgba(139, 108, 246, 0.1);
  animation: breathe 3s ease-in-out infinite 0.3s;
}

.ring-3 {
  width: 120px;
  height: 120px;
  border-color: rgba(139, 108, 246, 0.05);
  animation: breathe 3s ease-in-out infinite 0.6s;
}

.ai-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 40px rgba(139, 108, 246, 0.3);
  z-index: 10;
}

.ai-avatar .iconfont {
  font-size: 40px;
  color: #FFFFFF;
}

/* 信任标签行 */
.trust-tags-scroll {
  white-space: nowrap;
  margin-bottom: 24px;
}

.trust-tags-row {
  gap: 8px;
}

.trust-tag {
  background: #F7F5FF;
  padding: 6px 12px;
  flex-shrink: 0;
}

.trust-tag-icon {
  font-size: 14px;
  margin-right: 4px;
  color: #8B6CF6;
}

/* 主操作按钮 */
.main-action-section {
  margin-bottom: 24px;
}

.main-action-btn {
  width: 100%;
  height: 72px;
  padding: 0;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  box-shadow: 0 8px 24px rgba(139, 108, 246, 0.25);
}

.btn-content {
  padding: 0 24px;
}

.btn-left {
  gap: 12px;
}

.btn-icon {
  font-size: 24px;
  color: #FFFFFF;
}

.btn-text-group {
  text-align: left;
}

.btn-title {
  display: block;
  margin-bottom: 4px;
}

.btn-subtitle {
  display: block;
  opacity: 0.7;
}

.btn-arrow {
  font-size: 20px;
  color: #FFFFFF;
}

/* 快捷功能网格 */
.quick-features-section {
  margin-bottom: 32px;
}

.quick-feature-item {
  gap: 8px;
}

.feature-icon-wrapper {
  width: 56px;
  height: 56px;
  margin-bottom: 8px;
}

.feature-icon {
  font-size: 24px;
  color: #8B6CF6;
}

.feature-title {
  margin-bottom: 4px;
}

/* 最近项目区域 */
.recent-projects-section {
  margin-bottom: 24px;
}

.section-header {
  margin-bottom: 16px;
}

.section-title {
  font-weight: 600;
}

.view-all-btn {
  padding: 0;
  color: #8B6CF6;
}

.project-card {
  margin-bottom: 12px;
}

.project-top {
  gap: 12px;
}

.project-icon-wrapper {
  width: 40px;
  height: 40px;
  flex-shrink: 0;
}

.project-icon {
  font-size: 20px;
  color: #8B6CF6;
}

.project-meta {
  min-width: 0;
}

.project-name {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.project-status-row {
  gap: 8px;
}

.project-description {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.progress-track {
  width: 80px;
}

.progress-sm {
  height: 4px;
}

.margin-left-xs {
  margin-left: 4px;
}

.margin-left-md {
  margin-left: 8px;
}

.margin-left-lg {
  margin-left: 12px;
}

.margin-top-xs {
  margin-top: 4px;
}

.margin-top-md {
  margin-top: 8px;
}

.margin-top-lg {
  margin-top: 12px;
}

.bottom-spacer {
  height: 80px;
}
