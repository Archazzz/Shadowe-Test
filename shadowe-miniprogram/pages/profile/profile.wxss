/* pages/profile/profile.wxss */

.profile-header {
  padding-top: 24px;
}

.user-info-card {
  gap: 16px;
}

.user-avatar-wrapper {
  flex-shrink: 0;
}

.user-avatar {
  width: 64px;
  height: 64px;
  border-radius: 50%;
}

.user-meta {
  min-width: 0;
}

.user-name-row {
  gap: 8px;
}

.user-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.settings-icon {
  padding: 8px;
}

.settings-icon .iconfont {
  font-size: 24px;
  color: #9999AA;
}

.stats-grid {
  margin-top: 24px;
}

.stat-item {
  gap: 8px;
}

.stat-icon-wrapper {
  width: 48px;
  height: 48px;
}

.stat-icon {
  font-size: 20px;
  color: #8B6CF6;
}

.stat-value {
  text-align: center;
}

.stat-label {
  text-align: center;
}

.menu-section,
.settings-section {
  padding: 0 16px;
}

.menu-item {
  margin-bottom: 12px;
  gap: 12px;
}

.menu-icon-wrapper {
  width: 40px;
  height: 40px;
  flex-shrink: 0;
}

.menu-icon {
  font-size: 20px;
  color: #8B6CF6;
}

.menu-content {
  min-width: 0;
}

.menu-title {
  display: block;
  margin-bottom: 2px;
}

.menu-desc {
  display: block;
}

.menu-arrow {
  font-size: 16px;
  color: #D4D4E0;
}

.margin-left-lg {
  margin-left: 16px;
}

.margin-left-md {
  margin-left: 8px;
}

.margin-left-xs {
  margin-left: 4px;
}

.margin-top-xs {
  margin-top: 4px;
}

.margin-top-xl {
  margin-top: 24px;
}

.margin-top-lg {
  margin-top: 16px;
}

.bottom-spacer {
  height: 80px;
}
