/* pages/projects/projects.wxss */

.page-header {
  padding-top: 16px;
}

.search-filter-section {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.search-bar {
  flex: 1;
  height: 40px;
}

.search-icon {
  font-size: 16px;
  color: #9999AA;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #1A1A2E;
}

.placeholder-text {
  color: #9999AA;
}

.filter-dropdown {
  gap: 4px;
  padding: 8px 12px;
  background: #FFFFFF;
  border-radius: 9999px;
  border: 1px solid #E8E8F0;
}

.filter-text {
  font-size: 14px;
}

.filter-arrow {
  font-size: 12px;
  color: #9999AA;
}

.project-list {
  padding-bottom: 16px;
}

.project-card {
  margin-bottom: 12px;
}

.project-top {
  gap: 12px;
}

.project-icon-wrapper {
  width: 40px;
  height: 40px;
  flex-shrink: 0;
}

.project-icon {
  font-size: 20px;
  color: #8B6CF6;
}

.project-meta {
  min-width: 0;
}

.project-name-row {
  gap: 8px;
}

.project-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.project-meta-row {
  gap: 4px;
}

.more-action {
  padding: 4px;
}

.more-icon {
  font-size: 20px;
  color: #9999AA;
}

.project-description {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.progress-track {
  width: 80px;
}

.progress-sm {
  height: 4px;
}

.px-lg {
  padding-left: 16px;
  padding-right: 16px;
}

.margin-left-xs {
  margin-left: 4px;
}

.margin-left-sm {
  margin-left: 8px;
}

.margin-right-sm {
  margin-right: 8px;
}

.margin-top-xs {
  margin-top: 4px;
}

.margin-top-md {
  margin-top: 8px;
}

.margin-top-lg {
  margin-top: 12px;
}

.bottom-spacer {
  height: 100px;
}
